<UserControl x:Class="Benday.SqlUtils.WpfUi.Controls.OperationProgressBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:helpers="clr-namespace:Benday.SqlUtils.WpfUi.Controls"
    d:DesignHeight="100" d:DesignWidth="400" 
             Visibility="{Binding IsProgressBarVisible, Converter={StaticResource VisibilityValueConverterInstance}}">
    <Grid x:Name="LayoutRoot" Background="White">
        <Border>
            <StackPanel >
                <TextBlock Text="{Binding ProgressBarMessage}" Margin="4,40,4,4"  HorizontalAlignment="Center" TextWrapping="Wrap" />
                <ProgressBar x:Name="m_progressBar" Margin="6" Height="20" IsIndeterminate="{Binding IsProgressBarVisible}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
