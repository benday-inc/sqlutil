<Window x:Class="Benday.SqlServerUtilities.WpfUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Benday.SqlServerUtilities.WpfUi"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800" FontSize="18">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Dictionary1.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical" Style="{DynamicResource MenuStackPanel}">
            <Button x:Name="_ButtonSearchByName" Content="Search By Name" />
            <Button x:Name="_ButtonEditConnections" Content="Connections" />
        </StackPanel>

        <ContentControl 
            x:Name="_CurrentControl" 
            Grid.Column="1" />

    </Grid>
</Window>
