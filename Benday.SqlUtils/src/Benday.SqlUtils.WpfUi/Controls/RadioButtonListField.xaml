<UserControl x:Class="Benday.SqlServerUtilities.WpfUi.Controls.RadioButtonListField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Benday.SqlServerUtilities.WpfUi.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Style="{StaticResource DialogGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock 
            Grid.Row="0" 
            x:Name="_Label" 
            Text="LABEL TEXT" 
            VerticalAlignment="Top" 
            Margin="4" 
            TextWrapping="Wrap" 
            Style="{StaticResource FieldLabelStyle}"/>

        <TextBlock 
            Grid.Row="1" 
            Text="{Binding ValidationMessage}" 
            Style="{StaticResource FieldErrorStyle}" 
            Visibility="{Binding IsValid, Converter={StaticResource NotVisibilityValueConverterInstance}}" 
            Margin="4"/>
        <local:RadioButtonList Grid.Row="2" DataContext="{Binding Items}"/>
    </Grid>
</UserControl>
