<Window x:Class="Benday.SqlServerUtilities.WpfUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Benday.SqlServerUtilities.WpfUi"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800" FontSize="18" Loaded="Window_Loaded">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical" Style="{DynamicResource MenuStackPanel}">
            <Button x:Name="_ButtonSearchByName" Content="Search" Click="_ButtonSearchByName_Click" />
            <Button x:Name="_ButtonEditConnections" Content="Connections" Click="_ButtonEditConnections_Click" />
        </StackPanel>

        <ContentControl 
            x:Name="_CurrentControl" 
            Grid.Column="1" Loaded="_CurrentControl_Loaded" />

    </Grid>
</Window>
